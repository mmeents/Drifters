using Drifters.Core.Entities;
using Drifters.Core.Clients;
using Microsoft.Extensions.Logging;
using Drifters.Core.Constants;

namespace Drifters.Core.Services { 

  public interface ISetDesignerAgent {
      Task<string> GenerateSceneAsync(
          Run run,
          Tick tick,
          string previousContinuation,
          WorldState? worldState,
          CancellationToken ct = default);
      Task<string> GenerateContinuationAsync(
          Run run,
          Tick tick,
          IEnumerable<Turn> turns,
          WorldState? worldState,
          CancellationToken ct = default);
  }

  public class SetDesignerAgent() : ISetDesignerAgent {
    private readonly ILmStudioClient _lmStudio = new LmStudioClient(Cx.WorldStateLMStudioUrl);
    public async Task<string> GenerateSceneAsync(
        Run run,
        Tick tick,
        string previousContinuation,
        WorldState? worldState,
        CancellationToken ct = default)
    {
        var stateJson = worldState?.StateJson ?? "{}";
        var userPrompt = tick.TickNumber == 0
            ? $"{run.InitialScenario}\n\nWorld State: {stateJson}\n\n{Cx.SetDesignerSceneQuestion}"
            : $"{previousContinuation}\n\nWorld State: {stateJson}\n\n{Cx.SetDesignerSceneQuestion}";      
              
        var response = await _lmStudio.ChatAsync(
            run.SetDesignerModel,
            userPrompt,
            Cx.SetDesignerSystemPrompt,
            temperature: 0.7,
            ct: ct);  // this should invoke mcp tool call during the await, on the LM Studio server. 

        return response.GetText();
    }

      public async Task<string> GenerateContinuationAsync(
          Run run,
          Tick tick,
          IEnumerable<Turn> turns,
          WorldState? worldState,
          CancellationToken ct = default)
      {
          var stateJson = worldState?.StateJson ?? "{}";
          var turnSummaries = string.Join("\n", turns.Select(t =>
              $"- {t.Character?.Name ?? "Character"}: called {t.ToolCallName}({t.ToolCallArguments}) → {t.ToolCallResult}"));

          var userPrompt =
              $"{tick.SceneDescription}\n\n" +
              $"Character decisions this tick:\n{turnSummaries}\n\n" +
              $"World State: {stateJson}\n\n" +
              Cx.SetDesignerContinuationQuestion;
      

          var response = await _lmStudio.ChatAsync(
              run.SetDesignerModel,
              userPrompt,
              Cx.SetDesignerSystemPrompt,
              temperature: 0.7,
              ct: ct);

          return response.GetText();
      }
  }
}